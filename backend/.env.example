# ─── App ─────────────────────────────────────────────────
APP_NAME=Intelligent Policy Analyzer
APP_ENV=development
DEBUG=true

# ─── Database ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=policy_db

# ─── JWT ─────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── File Upload ─────────────────────────────────────────
UPLOAD_DIR=./uploads/raw_documents
EXTRACTED_DIR=./uploads/extracted_text
MAX_UPLOAD_MB=50

# ─── ML Models (all local, no external APIs) ────────────
EMBEDDING_MODEL=./models/all-MiniLM-L6-v2
CLASSIFIER_MODEL=./models/legal-bert-finetuned-v2
SUMMARIZER_MODEL=./models/t5-base
CHROMA_PERSIST_DIR=./data/vector_store

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
